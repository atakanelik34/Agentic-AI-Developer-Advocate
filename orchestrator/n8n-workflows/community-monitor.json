{
  "name": "RevenueCat Community Monitor",
  "active": false,
  "nodes": [
    {
      "name": "Hourly Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [300, 300],
      "parameters": {
        "rule": {
          "interval": [{"field": "cronExpression", "expression": "0 * * * *"}]
        }
      }
    },
    {
      "name": "Call Community Webhook",
      "type": "n8n-nodes-base.httpRequest",
      "position": [560, 300],
      "parameters": {
        "method": "POST",
        "url": "http://api:8000/webhook/trigger-community",
        "sendBody": true,
        "jsonBody": "{\"limit\": 50}"
      }
    }
  ],
  "connections": {
    "Hourly Trigger": {
      "main": [[{"node": "Call Community Webhook", "type": "main", "index": 0}]]
    }
  }
}
