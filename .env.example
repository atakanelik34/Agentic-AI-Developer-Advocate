# Anthropic (optional fallback)
ANTHROPIC_API_KEY=

# OpenAI (LLM + moderation)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MODERATION_MODEL=omni-moderation-latest

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Vertex AI (recommended on GCP VM with service account auth)
VERTEX_PROJECT_ID=revenuecat-agent
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
VERTEX_HEAVY_MODEL=gemini-2.5-pro
VERTEX_FLASH_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite
VERTEX_ACCESS_TOKEN=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# LLM routing
LLM_PRIMARY_PROVIDER=vertex
LLM_SECONDARY_PROVIDER=openai
LLM_TERTIARY_PROVIDER=gemini
LLM_TIMEOUT_MS=12000

# Moderation
MODERATION_PROVIDER=openai
MODERATION_TIMEOUT_MS=4000

# RevenueCat
REVENUECAT_API_KEY=
REVENUECAT_V1_API_KEY=
REVENUECAT_PROJECT_ID=
REVENUECAT_APP_ID=

# X / Twitter
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_EXPECTED_USERNAME=KairosAgentX

# GitHub
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_REPO=

# Hashnode
HASHNODE_API_KEY=
HASHNODE_PUBLICATION_ID=

# Discord (optional)
ENABLE_DISCORD=false
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Slack
SLACK_WEBHOOK_URL=

# Database
DATABASE_URL=postgresql://user:pass@postgres:5432/revenuecat_agent
REDIS_URL=redis://redis:6379/0

# Agent Identity
AGENT_NAME=KairosAgent
AGENT_START_DATE=2026-03-05

# Runtime modes
FORCE_AUTO_MODE=
QUALITY_MIN_SCORE=75
QUALITY_SIMILARITY_THRESHOLD=0.92
EXPERIMENT_SUCCESS_THRESHOLD=0.10

# Security
ADMIN_API_TOKEN=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# n8n
N8N_WEBHOOK_URL=

# Backup
BACKUP_REMOTE_URL=
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_RETENTION_DAILY=30
BACKUP_RETENTION_WEEKLY=12

# Observability
LOG_LEVEL=INFO
